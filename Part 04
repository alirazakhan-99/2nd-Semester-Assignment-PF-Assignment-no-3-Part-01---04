#include <iostream>
using namespace std;

// Problem 3: Function Overloading for Area Calculation
double calculateArea(double sideLength) {
    return sideLength * sideLength;
}

double calculateArea(double rectLength, double rectWidth) {
    return rectLength * rectWidth;
}

// Problem 4: Bowling Average
double getBowlingAverage(int runsConceded, int wicketsTaken) {
    if (wicketsTaken == 0) {
        return 0.0;
    }
    return (double) runsConceded / wicketsTaken;
}

// Problem 5: Print Vertical Word
void printVertical(char word[]) {
    for (int i = 0; word[i] != '\0'; i++) {
        cout << word[i] << endl;
    }
}

// Problem 6: Reverse Word
void reverseWord(char word[], int size) {
    int start = 0;
    int end = size - 1;
    while (start < end) {
        char temp = word[start];
        word[start] = word[end];
        word[end] = temp;
        start++;
        end--;
    }
}

int main() {
    cout << "=== PF Assignment 3 Part 4 ===" << endl;
    
    cout << "Area of Square (Side = 4.0): " << calculateArea(4.0) << endl;
    cout << "Area of Rectangle (5.0 x 3.0): " << calculateArea(5.0, 3.0) << endl;
    
    char word[] = "Code";
    reverseWord(word, 4);
    cout << "Reversed Word: " << word << endl;

    return 0;
}
